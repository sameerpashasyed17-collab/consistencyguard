# LLM provider: "anthropic" (default) or "openai"
PROVIDER=anthropic

# API keys — only the one matching your PROVIDER is required
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here

# Model name — must match provider
# Anthropic: claude-haiku-4-5-20251001 | claude-sonnet-4-6 | claude-opus-4-7
# OpenAI:    gpt-4o-mini | gpt-4o | gpt-4-turbo
MODEL=claude-haiku-4-5-20251001

# Detection thresholds
SIMILARITY_THRESHOLD=0.92      # prompt cosine similarity to trigger check
DIVERGENCE_THRESHOLD=0.25      # response divergence to flag a violation

# Only compare against calls from the last N days (prevents stale baselines).
# Leave unset to compare against ALL history (default, less safe for long-running agents).
COMPARISON_WINDOW_DAYS=30

# Database
DB_PATH=consistencyguard.db

# Optional: POST violation JSON here on every detection (Slack, PagerDuty, custom webhook)
WEBHOOK_URL=
